{
  "schemaVersion": 1,
  "id": "flat-lighting",
  "version": "${version}",
  "name": "Flat Lighting",
  "description": "A mod that disables shading on all models which makes lighting appear more flat.",
  "authors": [
    "Aeltumn"
  ],
  "contact": {},
  "license": "LGPL-3.0",
  "icon": "assets/flat-lighting/icon.png",
  "environment": "client",
  "entrypoints": {
    "sodium:config_api_user": [
      "com.aeltumn.flatlighting.sodium.FlatLightingSodiumOptions"
    ]
  },
  "mixins": [
    "flat-lighting.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.0",
    "minecraft": ">=26.1"
  }
}
